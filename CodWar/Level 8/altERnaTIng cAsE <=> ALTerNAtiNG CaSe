std::string to_alternating_case(const std::string& str)
{
  std::string res = "";
  for(int i = 0; i < str.length(); i++)
  {
    if(isupper(str[i]))
      res += tolower(str[i]);
    
    else if(islower(str[i]))
      res += toupper(str[i]);
    
    else 
      res += str[i];
    
  }
  
	return res;
}
