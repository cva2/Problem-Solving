#include <vector>
using namespace std;

int min(vector <int> list)
{
  int mins = list[0];
  for(int i = 0; i < list.size(); i++)
  {
    if(list[i] < mins)
      mins = list[i];
  }
  return mins;
}

int max(vector <int> list)
{
  int maxs = list[0];
  for(int i = 0; i < list.size(); i++)
  {
    if(list[i] > maxs)
      maxs = list[i];    
  }
  return maxs;
}
