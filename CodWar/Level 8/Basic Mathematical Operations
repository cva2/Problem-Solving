int basicOp(char op, int val1, int val2) {
  // Your code here
  switch(op)
  {
    case '+':
      return val1 + val2;
      break;
  
    case '-':
      return val1 - val2;
      break;

    case '*':
      return val1 * val2;
      break;

    case '/':
      return val1 / val2;
      break;
  }
}
